generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  PHARMACIST
  CASHIER
}

enum SaleStatus {
  COMPLETED
  VOIDED
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_MONEY
  BANK_TRANSFER
}

enum PurchaseOrderStatus {
  OPEN
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum AdjustmentReason {
  DAMAGE
  EXPIRED
  COUNT_CORRECTION
  RETURN_TO_SUPPLIER
  LOST
  THEFT_SUSPECTED
  OTHER
}

enum MovementType {
  STOCK_IN
  SALE
  RETURN
  DAMAGE
  EXPIRED
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
}

enum ReferenceType {
  STOCK_BATCH
  SALE
  INVENTORY_ADJUSTMENT
}

enum AuditAction {
  PHARMACY_SETUP_COMPLETED
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
  MEDICINE_CREATED
  MEDICINE_UPDATED
  STOCK_BATCH_CREATED
  STOCK_ADJUSTED
  SALE_CREATED
  SALE_VOIDED
  PURCHASE_ORDER_CREATED
  PURCHASE_ORDER_RECEIVED
  LOGIN_SUCCESS
  LOGIN_FAILED
}

model Pharmacy {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  country   String   @default("Ethiopia")
  currency  String   @default("ETB")
  timezone  String   @default("Africa/Addis_Ababa")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches             Branch[]
  users                User[]
  medicines            Medicine[]
  stockBatches         StockBatch[]
  purchaseOrders       PurchaseOrder[]
  sales                Sale[]
  inventoryAdjustments InventoryAdjustment[]
  stockMovements       StockMovement[]
  auditLogs            AuditLog[]

  @@map("pharmacies")
}

model Branch {
  id        String   @id @default(uuid())
  pharmacyId String
  name      String
  code      String
  address   String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pharmacy             Pharmacy             @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  users                User[]
  stockBatches         StockBatch[]
  purchaseOrders       PurchaseOrder[]
  sales                Sale[]
  inventoryAdjustments InventoryAdjustment[]
  stockMovements       StockMovement[]
  auditLogs            AuditLog[]

  @@unique([pharmacyId, code])
  @@map("branches")
}

model User {
  id           String    @id @default(uuid())
  pharmacyId   String
  branchId     String?
  fullName     String
  email        String    @unique
  passwordHash String
  role         UserRole
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  pharmacy            Pharmacy              @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  branch              Branch?               @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdBatches      StockBatch[]          @relation("StockBatchCreatedBy")
  createdPurchaseOrders PurchaseOrder[]     @relation("PurchaseOrderCreatedBy")
  sales               Sale[]                @relation("SaleSoldBy")
  inventoryAdjustments InventoryAdjustment[]
  stockMovements      StockMovement[]
  auditLogs           AuditLog[]

  @@map("users")
}

model Medicine {
  id          String   @id @default(uuid())
  pharmacyId  String
  name        String
  genericName String?
  brandName   String?
  sku         String?
  form        String?
  strength    String?
  category    String?
  unit        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pharmacy             Pharmacy              @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  stockBatches         StockBatch[]
  purchaseOrderItems   PurchaseOrderItem[]
  saleItems            SaleItem[]
  inventoryAdjustments InventoryAdjustment[]
  stockMovements       StockMovement[]

  @@index([pharmacyId, name])
  @@map("medicines")
}

model StockBatch {
  id             String    @id @default(uuid())
  pharmacyId     String
  branchId       String
  medicineId     String
  batchNumber    String
  expiryDate     DateTime
  quantityOnHand Int
  costPrice      Decimal   @db.Decimal(12, 2)
  sellingPrice   Decimal   @db.Decimal(12, 2)
  supplierName   String?
  receivedAt     DateTime  @default(now())
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  branch               Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  pharmacy             Pharmacy              @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  medicine             Medicine              @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  createdBy            User                  @relation("StockBatchCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  saleItems            SaleItem[]
  inventoryAdjustments InventoryAdjustment[]
  stockMovements       StockMovement[]

  @@index([branchId, medicineId, expiryDate])
  @@unique([branchId, medicineId, batchNumber])
  @@map("stock_batches")
}

model PurchaseOrder {
  id           String              @id @default(uuid())
  pharmacyId   String
  branchId     String
  orderNumber  String
  status       PurchaseOrderStatus @default(OPEN)
  supplierName String
  notes        String?
  createdById  String
  orderedAt    DateTime            @default(now())
  receivedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  pharmacy   Pharmacy            @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  branch     Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy  User                @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  items      PurchaseOrderItem[]

  @@unique([branchId, orderNumber])
  @@index([branchId, status, orderedAt])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String        @id @default(uuid())
  purchaseOrderId  String
  medicineId       String
  requestedQuantity Int
  receivedQuantity Int           @default(0)
  unitCost         Decimal       @db.Decimal(12, 2)
  createdAt        DateTime      @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  medicine      Medicine      @relation(fields: [medicineId], references: [id], onDelete: Restrict)

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

model Sale {
  id           String        @id @default(uuid())
  pharmacyId   String
  branchId     String
  saleNumber   String
  status       SaleStatus    @default(COMPLETED)
  totalAmount  Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @default(CASH)
  soldById     String
  soldAt       DateTime      @default(now())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  pharmacy       Pharmacy        @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  soldBy         User            @relation("SaleSoldBy", fields: [soldById], references: [id], onDelete: Restrict)
  items          SaleItem[]

  @@unique([branchId, saleNumber])
  @@index([branchId, soldAt])
  @@map("sales")
}

model SaleItem {
  id           String   @id @default(uuid())
  saleId       String
  medicineId   String
  stockBatchId String
  quantity     Int
  unitPrice    Decimal  @db.Decimal(12, 2)
  lineTotal    Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())

  sale       Sale       @relation(fields: [saleId], references: [id], onDelete: Cascade)
  medicine   Medicine   @relation(fields: [medicineId], references: [id], onDelete: Restrict)
  stockBatch StockBatch @relation(fields: [stockBatchId], references: [id], onDelete: Restrict)

  @@map("sale_items")
}

model InventoryAdjustment {
  id            String           @id @default(uuid())
  pharmacyId    String
  branchId      String
  medicineId    String
  stockBatchId  String
  reason        AdjustmentReason
  notes         String?
  quantityDelta Int
  createdById   String
  createdAt     DateTime         @default(now())

  branch     Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  pharmacy   Pharmacy   @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  medicine   Medicine   @relation(fields: [medicineId], references: [id], onDelete: Restrict)
  stockBatch StockBatch @relation(fields: [stockBatchId], references: [id], onDelete: Restrict)
  createdBy  User       @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([branchId, createdAt])
  @@map("inventory_adjustments")
}

model StockMovement {
  id            String        @id @default(uuid())
  pharmacyId    String
  branchId      String
  medicineId    String
  stockBatchId  String
  movementType  MovementType
  referenceType ReferenceType
  referenceId   String
  quantityDelta Int
  quantityAfter Int
  createdById   String
  createdAt     DateTime      @default(now())

  branch     Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  pharmacy   Pharmacy   @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  medicine   Medicine   @relation(fields: [medicineId], references: [id], onDelete: Restrict)
  stockBatch StockBatch @relation(fields: [stockBatchId], references: [id], onDelete: Restrict)
  createdBy  User       @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([branchId, medicineId, createdAt])
  @@map("stock_movements")
}

model AuditLog {
  id         String      @id @default(uuid())
  pharmacyId String
  branchId   String?
  userId     String?
  action     AuditAction
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  pharmacy   Pharmacy    @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  branch     Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([pharmacyId, createdAt])
  @@map("audit_logs")
}
